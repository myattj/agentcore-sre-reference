# Copy to .env.local for local Slack/OAuth development. Never commit real values.

# Slack app credentials from api.slack.com/apps/<your-app>
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_APP_ID=
SLACK_REDIRECT_URI=http://localhost:8000/slack/oauth/callback

# At least 32 random characters. Use the same value in onboarding/.env.local.
BRIDGE_OAUTH_STATE_SECRET=

# Local service routing
LOCAL_DEV=1
LOCAL_AGENT_URL=http://localhost:8080
ONBOARDING_BASE_URL=http://localhost:3000
BRIDGE_PUBLIC_URL=http://localhost:8000
AWS_REGION=us-west-2

# Public dashboard read guards. Trust forwarded addresses only behind a proxy
# you control; the reference ALB deployment sets that flag itself.
DASHBOARD_READS_PER_MINUTE=60
DASHBOARD_MAX_CONCURRENT_READS=16
DASHBOARD_TRUST_X_FORWARDED_FOR=

# Optional GitHub App integration
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_FILE=

# Optional operator and PR-sandbox surfaces
ADMIN_SECRET=
SANDBOX_CALLBACK_SECRET=
