# Onboarding Next.js service env vars.
# Copy to .env.local and fill in your local values.

# Server-side: base URL of the bridge API. Server components fetch the
# bridge through this; the browser never sees it.
BRIDGE_URL=http://localhost:8000

# Server-side: canonical browser origin for absolute redirects. Production
# must use HTTPS. Loopback HTTP is accepted for local development only.
ONBOARDING_PUBLIC_URL=http://localhost:3000

# Server-side: HMAC secret used to verify session tokens minted by the
# bridge OAuth callback. MUST match the bridge's BRIDGE_OAUTH_STATE_SECRET and
# contain at least 32 characters. If they drift, every onboarding session will
# fail with `bad_session`.
BRIDGE_OAUTH_STATE_SECRET=

# Public: the /slack/install URL on the bridge. Inlined into the landing
# page "Add to Slack" button. The only NEXT_PUBLIC_* var.
NEXT_PUBLIC_BRIDGE_INSTALL_URL=http://localhost:8000/slack/install

# Optional: enables the operator dashboard login and API proxy.
ADMIN_SECRET=

# Optional: enables the GitHub App install card during onboarding.
GITHUB_APP_SLUG=
